---
import CloudinaryImage from '../CloudinaryImage.astro';
const { section, content } = Astro.props;
const { cloudinary, cta } = content;
const img = section.image;
const stat = section.stat;          // optional signature numeral: { value, unit, label }
const dark = section.variant === 'dark';
// In the dark variant a hero image becomes a full-bleed background behind the
// copy + signature numeral (with a teal scrim for legibility); in the light
// variant it stays in the right column as a framed image.
const bgImage = dark && img;
// Signature cooling-cyan — high-contrast on the dark teal block (6.76:1). One-off accent
// for the signature moment; see 03b-design-brief.md (the "cold air made visible" numeral).
const SIGNATURE = '#19d3e0';
---
<section class:list={['relative overflow-hidden', dark ? 'bg-primary' : 'bg-bg-muted']}>
  {bgImage && (
    <div class="absolute inset-0">
      <CloudinaryImage
        cloudName={cloudinary.cloudName}
        publicId={img.publicId}
        alt={img.alt}
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
        class="h-full w-full object-cover"
      />
      <!-- Teal scrim over the photo. NOTE: bg-primary/NN opacity utilities don't
           render (the brand color is a CSS var holding a hex, so Tailwind can't
           compute the alpha and drops the rule), so we use an explicit rgba
           gradient. Strong + near-uniform so copy/label stay legible in the
           single-column mobile layout; ~10-20% of the photo still shows through. -->
      <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(10,58,64,0.92), rgba(10,58,64,0.8) 45%, rgba(10,58,64,0.92))"></div>
    </div>
  )}
  <div class="relative mx-auto grid max-w-ac items-center gap-10 px-6 py-16 sm:py-24 lg:grid-cols-2">
    <div class="reveal">
      {section.eyebrow && (
        <p
          class:list={['mb-4 text-sm font-semibold uppercase tracking-[0.12em]', { 'text-accent': !dark }]}
          style={dark ? `color:${SIGNATURE}` : undefined}
        >{section.eyebrow}</p>
      )}
      <h1 class:list={['font-heading text-5xl font-bold uppercase leading-[0.95] tracking-tight sm:text-6xl', dark ? 'text-primary-contrast [text-shadow:0_2px_18px_rgba(8,58,64,0.6)]' : 'text-ink']}>{section.headline}</h1>
      {section.subhead && (
        <p class:list={['mt-5 max-w-xl text-lg', dark ? 'text-primary-contrast [text-shadow:0_1px_14px_rgba(8,58,64,0.8)]' : 'text-muted']}>{section.subhead}</p>
      )}
      <div class="mt-8 flex flex-wrap items-center gap-4">
        {cta?.primary && (
          <a href={cta.primary.href} class="inline-flex items-center rounded-ac bg-accent px-6 py-3 font-semibold text-accent-contrast shadow-ac transition-transform hover:-translate-y-0.5">{cta.primary.label}</a>
        )}
        {cta?.transitional && (
          <a href={cta.transitional.href} class:list={['inline-flex items-center font-medium underline-offset-4 hover:underline', dark ? 'text-primary-contrast [text-shadow:0_1px_12px_rgba(8,58,64,0.8)]' : 'text-ink']}>{cta.transitional.label} →</a>
        )}
      </div>
    </div>

    {stat ? (
      <div class="reveal flex flex-col items-center justify-center text-center lg:items-end lg:text-right">
        <div class="flex items-start justify-center font-heading font-bold leading-none [text-shadow:0_2px_24px_rgba(8,58,64,0.55)]" style={`color:${SIGNATURE}`}>
          <span class="text-[8rem] sm:text-[11rem] lg:text-[13rem]">{stat.value}</span>
          {stat.unit && <span class="mt-4 text-4xl sm:text-5xl">{stat.unit}</span>}
        </div>
        {stat.label && (
          <p class:list={['mt-2 max-w-xs text-sm uppercase tracking-[0.12em]', dark ? 'text-primary-contrast [text-shadow:0_1px_12px_rgba(8,58,64,0.85)]' : 'text-muted']}>{stat.label}</p>
        )}
      </div>
    ) : img && !dark ? (
      <div class="reveal">
        <CloudinaryImage
          cloudName={cloudinary.cloudName}
          publicId={img.publicId}
          alt={img.alt}
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 1024px) 40rem, 100vw"
          class="aspect-[4/3] w-full rounded-ac object-cover shadow-ac"
        />
      </div>
    ) : null}
  </div>
</section>
